#!/usr/bin/env bash

# GPG 签名配置脚本 (macOS Apple Silicon 版)
# 完整流程：安装依赖、配置 pinentry-mac、生成/导入密钥、配置 Git

set -e

# 获取项目根目录
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$(dirname "$SCRIPT_DIR")")"

# 加载共享库
source "$PROJECT_ROOT/lib/common.sh"

# GPG 配置信息
GPG_EMAIL="i2cherry941219@gmail.com"
GPG_NAME="WanQuanXie"
GPG_SIGNING_KEY="4489322F7F539EA8"  # 预设签名密钥

show_group "GPG 签名配置"

# ============================================
# 1. 幂等性检查
# ============================================
show_info "检查是否已配置 GPG..."

if is_app_configured "gpg"; then
    show_success "GPG 已配置，跳过初始化"
    show_info "如需重新配置，请先运行: rm -f $HOME/.dotfiles_configured_gpg"
    exit 0
fi

# 检查是否已有 GPG 密钥
if gpg --list-secret-keys --keyid-format=long 2>/dev/null | grep -q "$GPG_SIGNING_KEY"; then
    show_info "检测到已存在的 GPG 密钥: $GPG_SIGNING_KEY"
    KEY_EXISTS=true
else
    KEY_EXISTS=false
fi

# ============================================
# 2. 安装依赖
# ============================================
show_progress "安装 GPG 相关依赖"

check_and_install_dependency "gpg" "gnupg"
check_and_install_dependency "pinentry-mac" "pinentry-mac"

# ============================================
# 3. 配置 gpg-agent.conf (pinentry-mac)
# ============================================
show_progress "配置 gpg-agent.conf"

ensure_directory "$HOME/.gnupg"
chmod 700 "$HOME/.gnupg"

GPG_AGENT_CONF="$HOME/.gnupg/gpg-agent.conf"

# 如果文件不存在或不含 pinentry-mac，则添加配置
if [[ ! -f "$GPG_AGENT_CONF" ]] || ! grep -q "pinentry-mac" "$GPG_AGENT_CONF" 2>/dev/null; then
    backup_file "$GPG_AGENT_CONF"
    cat >> "$GPG_AGENT_CONF" << 'EOF'

# pinentry-mac 配置 (解决 macOS GPG 签名失败问题)
pinentry-program /opt/homebrew/bin/pinentry-mac
EOF
    show_success "已配置 pinentry-mac"
else
    show_info "pinentry-mac 已配置"
fi

# ============================================
# 4. 配置 GPG_TTY 环境变量
# ============================================
show_progress "配置 GPG_TTY 环境变量"

ZSHRC="$HOME/.zshrc"

if [[ ! -f "$ZSHRC" ]] || ! grep -q "GPG_TTY" "$ZSHRC" 2>/dev/null; then
    backup_file "$ZSHRC"
    cat >> "$ZSHRC" << 'EOF'

# GPG TTY 配置 (解决签名时无法输入密码的问题)
GPG_TTY=$(tty)
export GPG_TTY
EOF
    show_success "已添加 GPG_TTY 到 ~/.zshrc"
else
    show_info "GPG_TTY 已配置"
fi

# 立即导出当前 TTY
GPG_TTY=$(tty)
export GPG_TTY

# ============================================
# 5. 生成/验证 GPG 密钥
# ============================================
show_progress "检查 GPG 密钥"

if [[ "$KEY_EXISTS" == "true" ]]; then
    show_success "GPG 密钥已存在: $GPG_SIGNING_KEY"
else
    show_info "未检测到预设密钥，开始生成新密钥..."

    # 创建临时批处理文件用于 GPG 密钥生成
    cat > /tmp/gpg-batch << EOF
%echo 正在生成 GPG 密钥
Key-Type: RSA
Key-Length: 4096
Subkey-Type: RSA
Subkey-Length: 4096
Name-Real: $GPG_NAME
Name-Email: $GPG_EMAIL
Expire-Date: 0
%no-protection
%commit
%echo 完成
EOF

    # 使用批处理文件生成密钥
    if gpg --batch --generate-key /tmp/gpg-batch; then
        show_success "GPG 密钥生成成功"
    else
        show_error "GPG 密钥生成失败"
    fi

    # 清理临时批处理文件
    rm -f /tmp/gpg-batch
fi

# 获取密钥 ID（优先使用预设密钥）
if [[ -n "$GPG_SIGNING_KEY" ]]; then
    KEY_ID="$GPG_SIGNING_KEY"
else
    KEY_ID=$(gpg --list-secret-keys --keyid-format=long 2>/dev/null | grep -E "^sec" | head -n 1 | sed -E 's/.*\/([A-F0-9]+) .*/\1/')
fi

if [[ -z "$KEY_ID" ]]; then
    show_error "无法提取 GPG 密钥 ID"
    exit 1
fi

show_info "当前使用密钥 ID: $KEY_ID"

# 显示密钥信息
echo ""
show_info "GPG 密钥详情："
gpg --list-secret-keys --keyid-format=long 2>/dev/null || true

# ============================================
# 6. 配置 Git GPG 设置
# ============================================
show_progress "配置 Git GPG 签名"

# 检查 rc/gitconfig 是否已配置
if [[ -f "$PROJECT_ROOT/rc/gitconfig" ]]; then
    show_info "检测到 Git 配置文件，使用预设值"
else
    # 如果没有配置文件，手动设置
    git config --global user.signingkey "$KEY_ID" 2>/dev/null || true
fi

# 确保 Git GPG 签名开启
git config --global commit.gpgsign true 2>/dev/null || true
git config --global tag.gpgSign true 2>/dev/null || true

# 配置 GPG 程序路径
if command -v gpg > /dev/null; then
    git config --global gpg.program "$(which gpg)"
fi

# 验证 Git 配置
show_info "Git GPG 配置状态："
echo "  签名密钥: $(git config --global user.signingkey || echo '未设置')"
echo "  自动签名: $(git config --global commit.gpgsign || echo '未设置')"
echo "  GPG 程序: $(git config --global gpg.program || echo '默认')"

# ============================================
# 7. 重启 gpg-agent
# ============================================
show_progress "重启 gpg-agent"

gpgconf --kill gpg-agent 2>/dev/null || true
show_success "gpg-agent 已重启"

# ============================================
# 8. 标记完成
# ============================================
mark_app_configured "gpg"

# ============================================
# 输出总结
# ============================================
echo ""
show_group "GPG 配置完成"
show_success "GPG 签名配置已成功完成！"

echo ""
echo "===== 使用说明 ====="
echo "1. 测试 GPG 签名："
echo "   echo 'test' | gpg --clearsign"
echo ""
echo "2. 验证 Git 提交签名："
echo "   git log --show-signature -1"
echo ""
echo "3. 如果遇到问题，请检查："
echo "   - GPG_TTY 环境变量: echo \$GPG_TTY"
echo "   - pinentry 配置: cat ~/.gnupg/gpg-agent.conf"
echo ""
